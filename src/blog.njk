---
layout: base.njk
title: Blog — Philip Zhang
---

<section class="section">
  <h2 class="section-title">Blog</h2>
  <div class="blog-list">
    {% set blogPosts = collections.blog | reverse %}
    {% for post in blogPosts %}
    <a href="{{ post.url }}" class="blog-list-item">
      <h3>{{ post.data.title }}</h3>
      <time>{{ post.date | dateFormat }}</time>
      {% if post.data.excerpt %}
      <p>{{ post.data.excerpt }}</p>
      {% endif %}
    </a>
    {% endfor %}
    {% if not collections.blog or collections.blog.length == 0 %}
    <p class="empty-state">No posts yet. Check back soon!</p>
    {% endif %}
  </div>
</section>
