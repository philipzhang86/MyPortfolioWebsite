---
layout: base.njk
---

<article class="blog-post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <time class="post-date">{{ date | dateFormat }}</time>
  </header>
  <div class="post-content">
    {{ content | safe }}
  </div>
  <a href="/blog/" class="back-link">&larr; Back to all posts</a>
</article>
